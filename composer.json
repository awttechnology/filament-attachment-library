{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "awttechnology/filament-attachment-library",
    "description": "A standalone Filament attachment library with BunnyCDN support and Glide image processing.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "intervention/image": "^2.0",
        "league/glide-symfony": "^2.0",
        "livewire/livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "AwtTechnology\\FilamentAttachmentLibrary\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AwtTechnology\\FilamentAttachmentLibrary\\AttachmentLibraryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
